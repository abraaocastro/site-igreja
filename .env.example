# ===============================================
# Variáveis de ambiente do site PIBAC
# ===============================================
# Copie este arquivo para `.env.local` e preencha com seus valores.
# NUNCA commite `.env.local` — ele está no .gitignore.

# --- Supabase (auth + dados) ---
# Project URL e publishable key são públicos, podem ir no bundle.
# Pegue em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Service role key — APENAS SERVER-SIDE. NUNCA use NEXT_PUBLIC_ nem commite.
# Necessária para:
#   - Rodar scripts/bootstrap-admin.ts (criação do admin inicial)
#   - Route handlers que criam/deletam usuários (admin convidando conteudistas)
# Em produção, configure no painel da Vercel em Environment Variables
# (Server-side only, não expõe no browser).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Identidade do site ---
# URL canônica usada no JSON-LD (Schema.org) pra ajudar o Google a ligar
# esta página à entidade da igreja. Sem barra no final.
# Produção: Vercel define automaticamente em Preview; aqui aponte pro domínio final
# (ex: https://pibac.com.br quando for registrado).
NEXT_PUBLIC_SITE_URL=https://pibac.vercel.app
