# ===============================================
# Variáveis de ambiente do site PIBAC
# ===============================================
# Copie este arquivo para `.env.local` e preencha com seus valores.
# NUNCA commite `.env.local` — ele está no .gitignore.

# --- Autenticação (DEMO, client-side) ---
# Credenciais do painel /admin. Qualquer pessoa com acesso ao bundle
# JavaScript pode ler esses valores. Use apenas como placeholder até
# implementar uma auth real (NextAuth/Clerk/Supabase/Firebase).
NEXT_PUBLIC_ADMIN_EMAIL=conteudista@pibac.local
NEXT_PUBLIC_ADMIN_PASSWORD=troque-esta-senha

# --- Identidade do site ---
# URL canônica usada no JSON-LD (Schema.org) pra ajudar o Google a ligar
# esta página à entidade da igreja. Sem barra no final.
# Produção: Vercel define automaticamente em Preview; aqui aponte pro domínio final
# (ex: https://pibac.com.br quando for registrado).
NEXT_PUBLIC_SITE_URL=https://pibac.vercel.app
